@startuml c4-component
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()

title Component diagram for Task Worker

Container_Boundary(worker, "Task Worker") {
    Component(grading_agent, "Grading Agent", "LangGraph StateGraph", "Orchestrates tool calls: decides which checks to run and in what order")
    Component(qa_agent, "Q&A Agent", "LangGraph StateGraph", "Answers student questions, triggers recheck when requested")
    Component(deterministic_tools, "Deterministic Tools", "Python functions", "Artifact checks, DoD parsing, deadline calculation, roster lookup, spec fetching, file reading, past reviews")
    Component(eval_subagent, "Content Evaluator", "LangGraph sub-agent", "Evaluates document quality against rubric criteria via LLM")
    Component(sandbox_subagent, "Code Review Agent", "LangGraph sub-agent + E2B", "Reviews code in sandbox: runs build, tests, checks quality, posts inline comments")
    Component(github_client, "GitHub Client", "gidgethub, httpx", "Reads PR files, posts comments, creates inline reviews, manages labels")
    Component(sheets_client, "Sheets Client", "aiogoogle", "Reads roster, rubrics, deadlines; writes grading results")
    Component(llm_client, "LLM Client", "langchain-openai", "Wraps Z.AI API calls with tool binding and structured output")
    Component(sanitizer, "Input Sanitizer", "Python regex", "Detects prompt injection patterns, wraps student content in structural isolation markers")
}

System_Ext(github, "GitHub API")
System_Ext(zai, "Z.AI API")
System_Ext(e2b, "E2B API")
System_Ext(sheets, "Google Sheets API")

Rel(grading_agent, deterministic_tools, "Calls for artifact checks, deadlines, DoD")
Rel(grading_agent, eval_subagent, "Calls to evaluate document content")
Rel(grading_agent, sandbox_subagent, "Calls to review code in sandbox")
Rel(grading_agent, github_client, "Posts grading report and inline reviews")
Rel(grading_agent, sheets_client, "Writes grading results")

Rel(qa_agent, deterministic_tools, "Reads files and specs for context")
Rel(qa_agent, grading_agent, "Triggers recheck via task queue")

Rel(eval_subagent, sanitizer, "Sanitizes student content before evaluation")
Rel(eval_subagent, llm_client, "Sends evaluation prompt")
Rel(sandbox_subagent, llm_client, "Sends code review prompts in tool-use loop")
Rel(sandbox_subagent, github_client, "Posts inline review comments on PR")
Rel(grading_agent, llm_client, "Sends orchestration prompts")

Rel(github_client, github, "Reads and writes via REST API", "HTTPS")
Rel(llm_client, zai, "Sends chat completions", "HTTPS")
Rel(sandbox_subagent, e2b, "Creates and manages sandboxes", "HTTPS")
Rel(sheets_client, sheets, "Reads and writes via Sheets API", "HTTPS")

@enduml
