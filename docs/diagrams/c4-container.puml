@startuml c4-container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title Container diagram for Project Judge

Person(student, "Student")
Person(instructor, "Instructor")

System_Boundary(judge, "Project Judge") {
    Container(app, "Webhook Service", "Python, Granian", "Receives GitHub webhooks, verifies HMAC signature, enqueues grading tasks")
    Container(worker, "Task Worker", "Python, Taskiq", "Runs LangGraph grading agent and Q&A agent with tool-use loop")
    ContainerDb(redis, "Redis", "Redis 7", "Message broker for async task dispatch")
}

System_Ext(github, "GitHub", "Repos, PRs, webhooks, code review API")
System_Ext(zai, "Z.AI", "GLM-4.7 LLM inference")
System_Ext(e2b, "E2B", "Firecracker sandbox API")
System_Ext(sheets, "Google Sheets", "Roster, rubrics, deadlines, results")
System_Ext(langfuse, "Langfuse", "LLM tracing")

Rel(student, github, "Pushes code and opens PR")
Rel(instructor, github, "Reviews escalated PRs")
Rel(instructor, sheets, "Edits rubrics and deadlines")

Rel(github, app, "Sends webhook on PR event", "HTTPS")
Rel(app, redis, "Enqueues grade_pr and answer_question tasks")
Rel(worker, redis, "Dequeues and executes tasks")

Rel(worker, github, "Reads files, posts comments, creates inline reviews", "HTTPS")
Rel(worker, zai, "Sends prompts for grading and content evaluation", "HTTPS")
Rel(worker, e2b, "Creates sandbox, runs build and tests, destroys sandbox", "HTTPS")
Rel(worker, sheets, "Reads roster and rubrics, writes grading results", "HTTPS")
Rel(worker, langfuse, "Sends LLM call traces", "HTTPS")

@enduml
