@startuml c4-context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title System Context diagram for Project Judge

Person(student, "Student", "Submits lab deliverables as GitHub PR")
Person(instructor, "Instructor", "Manages rubrics, reviews escalated PRs")

System(judge, "Project Judge", "Automated grading system: checks artifacts, evaluates documents, reviews code, posts feedback")

System_Ext(github, "GitHub", "Hosts student repositories and pull requests")
System_Ext(zai, "Z.AI", "Provides LLM inference via OpenAI-compatible API")
System_Ext(e2b, "E2B", "Runs student code in isolated Firecracker sandboxes")
System_Ext(sheets, "Google Sheets", "Stores roster, rubrics, deadlines, and grading results")
System_Ext(langfuse, "Langfuse", "Collects LLM traces for observability")

Rel(student, github, "Pushes code and opens PR")
Rel(github, judge, "Sends webhook on PR open or comment")
Rel(judge, github, "Posts grading comments and inline code reviews")
Rel(judge, zai, "Sends prompts, receives completions")
Rel(judge, e2b, "Creates sandboxes, executes build and tests")
Rel(judge, sheets, "Reads roster and rubrics, writes grading results")
Rel(judge, langfuse, "Sends LLM call traces asynchronously")
Rel(instructor, sheets, "Edits rubrics and deadlines")
Rel(instructor, github, "Reviews PRs labeled needs-review")

@enduml
